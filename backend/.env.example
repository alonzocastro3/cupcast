# Copy to .env for local development (outside Docker)
DATABASE_URL=postgresql+asyncpg://cupcast:cupcast@localhost:5432/cupcast
REDIS_URL=redis://localhost:6379
CORS_ORIGINS=http://localhost:3000

# Football data provider (optional — only needed for live data ingestion)
# Get a free key at https://www.football-data.org/client/register
# FOOTBALL_API_KEY=your_key_here
# FOOTBALL_TOURNAMENT_ID=WC
# FOOTBALL_API_BASE_URL=https://api.football-data.org
# FOOTBALL_API_TIMEOUT=10.0
# FOOTBALL_API_MAX_RETRIES=3

# Background worker (optional — defaults shown)
# SYNC_INTERVAL_SECONDS=900   # 15 minutes between syncs
# SYNC_LOCK_KEY=20261001      # PostgreSQL advisory lock key
